# Hostname or IP of the ESP32 running ESPHome bluetooth_proxy
ESPHOME_HOST=192.168.1.50
ESPHOME_PORT=6053
# One of password or encryption key (encryption key recommended)
ESPHOME_PASSWORD=
ESPHOME_ENCRYPTION_KEY=

# BLE MAC of the Reverie controller (find it with the iOS app once or via ESPHome web UI)
REVERIE_BLE_ADDRESS=AA:BB:CC:DD:EE:FF

# Where to persist schedules
SCHEDULES_FILE=./data/schedules.json

# REST API
PORT=8080
API_TOKEN=change-me
